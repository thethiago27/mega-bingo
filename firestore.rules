rules_version = '2';

// This project uses the Realtime Database (see database.rules.json), not
// Firestore. Deny all Firestore access so an unused, wide-open ruleset can't
// be deployed by accident.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
