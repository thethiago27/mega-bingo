{
  "rules": {
    "rooms": {
      ".read": true,
      "$roomId": {
        ".read": true,
        ".write": "auth != null && (!data.exists() || data.child('adminId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['name', 'adminId', 'createdAt', 'gameState'])",
        "adminId": {
          ".validate": "newData.isString()"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "gameState": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'in_progress' || newData.val() === 'completed')"
        },
        "currentRound": {
          ".validate": "newData.isNumber() && newData.val() >= 1"
        },
        "players": {
          "$playerId": {
            ".write": true,
            ".validate": "newData.hasChildren(['name', 'cardNumbers', 'markedNumbers'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
            }
          }
        },
        "$other": {
          ".validate": true
        }
      }
    }
  }
}
